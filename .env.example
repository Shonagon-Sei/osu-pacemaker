# ─────────────────────────────────────────────────────────────────────────────
# osu! installation paths. Supports BOTH stable and lazer; by default it
# auto-detects whichever exist. Only set these if your install is in a custom
# spot. Forward slashes or double backslashes both work.
#
#   Stable default:  C:\Users\<you>\AppData\Local\osu!     (has Data\r, scores.db)
#   Lazer default:   C:\Users\<you>\AppData\Roaming\osu    (has client.realm, files\)
# ─────────────────────────────────────────────────────────────────────────────
# OSU_STABLE_ROOT=C:\Users\User\AppData\Local\osu!
# OSU_LAZER_ROOT=C:\Users\User\AppData\Roaming\osu

# Which install(s) to index:  auto (default) | stable | lazer
OSU_MODE=auto

# tosu websocket — v2 API (default install). https://tosu.app/
TOSU_URL=ws://127.0.0.1:24050/websocket/v2

# Local websocket the overlay connects to
RELAY_PORT=7270

# Static file server for the overlay HTML (open http://localhost:<this>/ in OBS browser source)
HTTP_PORT=7271

# Simulation granularity in milliseconds (timeline sample step). 100 = 10 samples/sec.
SIM_STEP_MS=100

# Max worker threads for parallel replay simulation (0 = auto = cpuCount-1)
SIM_WORKERS=0

# Only show the top N ghosts (by final score) on the overlay. 0 = unlimited.
MAX_GHOSTS=7

# Re-scan the replay folder header index on every map change (true) or cache aggressively (false)
WATCH_REPLAYS=true

# ─────────────────────────────────────────────────────────────────────────────
# osu! API v2 — enables the "global top scores as ghosts" option in the overlay.
# Create an OAuth app at  https://osu.ppy.sh/home/account/edit  (Client ID/Secret).
# Only the client_id/secret are needed (no user login). Leave blank to disable.
# ─────────────────────────────────────────────────────────────────────────────
OSU_API_CLIENT_ID=
OSU_API_CLIENT_SECRET=
# Default number of global scores to pull (1-100; overridable in the overlay UI)
OSU_GLOBAL_COUNT=50
